{
  "python": {
    "image": "python:3.12-alpine",
    "filename": "main.py",
    "command": "python3 {file}"
  },
  "cpp": {
    "image": "gcc:14",
    "filename": "main.cpp",
    "command": "g++ -O2 -std=c++17 {file} -o app && ./app"
  },
  "javascript": {
    "image": "node:22-alpine",
    "filename": "main.js",
    "command": "node {file}"
  },
  "java": {
    "image": "eclipse-temurin:21",
    "filename": "Main.java",
    "command": "javac {file} && java Main"
  },
  "go": {
    "image": "golang:1.24-alpine",
    "filename": "main.go",
    "command": "/usr/local/go/bin/go run {file}"
  }
}
